// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
	ADMIN
	MANAGER
	STAFF //WAITER, POS OPERATOR
	KITCHEN //CHEFS
	CUSTOMER
}



model User {
	id            String    @id @default(auto()) @map("_id") @db.ObjectId
	name          String?
	email         String    @unique
	emailVerified Boolean
	image         String?
	role 		Role @default(CUSTOMER)
	status 		String @default("active")
	age 		Int?
	gender 		String?
	phone 		String?
	banned 		Boolean @default(false)
	bannedReason	String?
	// Relations
	sessions Session[]
	accounts Account[]
	activitiesLog ActivitiesLog[]
	feedback Feedbacks[]
	table Table[]
	createdAt     DateTime  @default(now())
	updatedAt     DateTime  @updatedAt
	@@map("user")
	
}
model Session {
	id        String   @id @default(auto()) @map("_id") @db.ObjectId
	userId    String   @db.ObjectId
	token     String   @unique
	expiresAt DateTime
	ipAddress String?
	userAgent String?
	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt
	// Relations
	user User @relation(fields: [userId], references: [id], onDelete: Cascade)
	@@map("session")
}
model Account {
	id                   String    @id @default(auto()) @map("_id") @db.ObjectId
	userId               String    @db.ObjectId
	accountId            String
	providerId           String
	accessToken          String?
	refreshToken         String?
	accessTokenExpiresAt DateTime?
	refreshTokenExpiresAt DateTime?
	scope                String?
	idToken              String?
	password             String?
	createdAt            DateTime  @default(now())
	updatedAt            DateTime  @updatedAt
	// Relations
	user User @relation(fields: [userId], references: [id], onDelete: Cascade)
	@@map("account")
}
model Verification {
	id         String   @id @default(auto()) @map("_id") @db.ObjectId
	identifier String
	value      String
	expiresAt  DateTime
	createdAt  DateTime @default(now())
	updatedAt  DateTime @updatedAt
	@@map("verification")
}

model Category {
	id 	String  @id @default(auto()) @map("_id") @db.ObjectId
	name String @unique
	slung String @unique

	menu MenuItem[]
}

model ActivitiesLog {
	id String @id @default(auto()) @map("_id") @db.ObjectId
	userId String @db.ObjectId
	action String
	details String
	createdAt DateTime @default(now())

	user User @relation(fields: [userId], references: [id])
	@@map("activities_log")
}

model Feedbacks{
	id String @id @default(auto()) @map("_id") @db.ObjectId
	rating Int
	comment String
	userId String? @db.ObjectId
	menuItemId String @db.ObjectId
	//relation
	user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
	menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
	createAt DateTime @default(now())

	@@map("feedbacks")
}

model MenuItem{
	id String @id @default(auto()) @map("_id") @db.ObjectId
	name String
	description Json?
	price Float
	discount Float? @default(0)
	image String
	isAvailable Boolean @default(true)
	recipe String?
	categoryId String @db.ObjectId
	aiSuggestion String?
	//relation
	category Category @relation(fields: [categoryId], references: [id])
	feedback Feedbacks[]

}

enum TableType{
	circle
	square
	rectangle
}
enum TableStatus{
	OCCUPIED
	AVAILABLE
	RESERVED
}
model Table {
	id String @id @default(auto()) @map("_id") @db.ObjectId
	tableName String @unique
	seats Int
	section String @default("Main Dinning Room")
	shape TableType @default(square)
	tableStatus TableStatus @default(AVAILABLE)
	userId String @db.ObjectId
	createAt DateTime @default(now())

	user User @relation(fields: [userId], references: [id])

}

model Reservation{
	id String @id @default(auto()) @map("_id") @db.ObjectId

	@@map("reservation")
}

model Orders{
	id String @id @default(auto()) @map("_id") @db.ObjectId

	@@map("orders")
}

